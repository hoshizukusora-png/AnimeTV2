<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape><solid android:color="#1E1E1E"/><stroke android:width="1.5dp" android:color="#E91E8C"/><corners android:radius="6dp"/></shape>
    </item>
    <item android:state_pressed="true">
        <shape><solid android:color="#252015"/><corners android:radius="6dp"/></shape>
    </item>
    <item>
        <shape><solid android:color="#141414"/><stroke android:width="0.5dp" android:color="#22FFFFFF"/><corners android:radius="6dp"/></shape>
    </item>
</selector>

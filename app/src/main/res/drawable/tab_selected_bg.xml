<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state (remote D-pad hover) -->
    <item android:state_focused="true">
        <shape>
            <solid android:color="#2A1A3E"/>
            <stroke android:width="1dp" android:color="#E91E8C"/>
        </shape>
    </item>
    <!-- Selected/active tab -->
    <item>
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#1A1A2E"/>
                </shape>
            </item>
            <!-- Garis bawah pink sebagai indikator aktif -->
            <item android:gravity="bottom">
                <shape>
                    <solid android:color="#E91E8C"/>
                    <size android:height="3dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/color_background"
    android:padding="32dp">

    <!-- Background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_anime_1"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        android:layout_gravity="center"/>

    <!-- Logo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANIME"
        android:textColor="@color/color_primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TELEVISION"
        android:textColor="@color/color_text_dim"
        android:textSize="14sp"
        android:letterSpacing="0.3"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <!-- Activation Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/quote_card_bg"
        android:padding="24dp"
        android:maxWidth="400dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aktivasi Aplikasi"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Masukkan kode aktivasi untuk menggunakan AnimeTV"
            android:textColor="@color/color_text_dim"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="24dp"/>

        <!-- Device ID info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Device ID:"
                android:textColor="@color/color_text_dim"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/txt_device_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_accent"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Input kode -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Kode Aktivasi (ANIM-XXXX-XXXX-XXXX)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_license_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:textSize="14sp"
                android:letterSpacing="0.1"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Loading -->
        <com.github.ybq.android.spinkit.SpinKitView
            android:id="@+id/loading_activation"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:SpinKit_Style="Wave"
            app:SpinKit_Color="@color/color_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Status text -->
        <TextView
            android:id="@+id/txt_activation_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="16dp"
            android:visibility="gone"/>

        <!-- Tombol aktivasi -->
        <Button
            android:id="@+id/btn_activate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Aktifkan Sekarang"
            android:textSize="14sp"
            android:backgroundTint="@color/color_primary"/>

    </LinearLayout>

    <!-- Info kontak -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Belum punya kode aktivasi? Hubungi admin."
        android:textColor="@color/color_text_dim"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="24dp"/>

</LinearLayout>

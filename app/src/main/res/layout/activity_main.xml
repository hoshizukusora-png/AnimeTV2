<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="catAdapter" type="com.animatv.player.adapter.CategoryAdapter"/>
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background"
        tools:context=".MainActivity">

    <!-- Anime background -->
    <ImageView
        android:id="@+id/img_anime_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_anime_1"
        android:scaleType="centerCrop"
        android:alpha="0.06"/>

    <!-- Sakura overlay -->
    <FrameLayout
        android:id="@+id/sakura_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"/>

    <!-- MAIN LAYOUT: Nav | Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ===== TVX LEFT NAV SIDEBAR ===== -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/color_nav_bg"
            android:paddingTop="0dp">

            <!-- TVX Logo Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:background="@drawable/sidebar_header_bg">

                <!-- TVX Play icon triangle -->
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="&#9654;"
                    android:textColor="#3B82F6"
                    android:textSize="14sp"
                    android:background="@drawable/tvx_play_btn"
                    android:layout_marginEnd="8dp"/>

                <!-- App Name -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/txt_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TVX"
                        android:textColor="@color/color_text"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AnimeTV"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="9sp"/>
                </LinearLayout>

                <!-- Notification icon -->
                <ImageButton
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/button_control_background"
                    android:padding="6dp"
                    app:srcCompat="@drawable/ic_search"
                    android:tint="@color/color_text_secondary"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- Separator -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#151E35"/>

            <!-- User profile card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/user_card_bg">

                <!-- Avatar circle -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="K"
                    android:textColor="#3B82F6"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/user_avatar_bg"
                    android:layout_marginEnd="10dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KawailUser"
                        android:textColor="@color/color_text"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View android:layout_width="5dp" android:layout_height="5dp"
                            android:background="@drawable/dot_green"
                            android:layout_marginEnd="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Online"
                            android:textColor="@color/color_green"
                            android:textSize="9sp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Nav section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MENU"
                android:textColor="@color/color_text_dim"
                android:textSize="8sp"
                android:letterSpacing="0.2"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

            <!-- Nav items (using RecyclerView for categories) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sidebar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"/>

            <!-- Anime quote card -->
            <LinearLayout
                android:id="@+id/quote_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/quote_card_bg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#34;"
                        android:textColor="@color/color_primary"
                        android:textSize="14sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/txt_quote_anime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/color_primary"
                        android:textSize="7sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        tools:text="NARUTO"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txt_quote_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text"
                    android:textSize="8sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    tools:text="Jangan menyerah! Seseorang yang menyerah adalah orang yang lemah."/>

                <TextView
                    android:id="@+id/txt_quote_character"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dim"
                    android:textSize="7sp"
                    android:gravity="end"
                    tools:text="- Naruto Uzumaki"/>
            </LinearLayout>

            <!-- Footer: quality selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="10dp"
                android:background="@drawable/sidebar_footer_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KUALITAS VIDEO"
                    android:textSize="7sp"
                    android:textColor="@color/color_text_dim"
                    android:letterSpacing="0.15"
                    android:paddingBottom="5dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView style="@style/ResBtn" android:text="360p"/>
                    <TextView style="@style/ResBtnActive" android:text="720p" android:layout_marginStart="2dp"/>
                    <TextView style="@style/ResBtn" android:text="1080p" android:layout_marginStart="2dp"/>
                    <TextView style="@style/ResBtn" android:text="4K" android:layout_marginStart="2dp"/>
                    <TextView style="@style/ResBtn" android:text="Auto" android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Sidebar separator -->
        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="#151E35"/>

        <!-- ===== MAIN CONTENT AREA ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- ===== TOP BAR ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="10dp"
                android:background="@drawable/topbar_bg">

                <!-- Page tabs: Home / For You -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/text_current_cat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home"
                        android:textColor="@color/color_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:paddingEnd="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="For You"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Flex spacer -->
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <!-- Refresh icon -->
                <ImageButton android:id="@+id/button_refresh" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh"
                    android:layout_marginEnd="4dp"/>

                <!-- Notification/chat icon -->
                <ImageButton android:id="@+id/button_settings" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search"
                    android:layout_marginEnd="4dp"/>

                <!-- Clock -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/text_clock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/color_accent"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/text_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Senin"
                        android:textColor="#66FFFFFF"
                        android:textSize="7sp"/>
                </LinearLayout>

                <!-- Search button -->
                <ImageButton android:id="@+id/button_search" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search"
                    android:layout_marginStart="2dp"/>

                <!-- Exit button -->
                <ImageButton android:id="@+id/button_exit" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_exit"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- Topbar bottom line -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#151E35"/>

            <!-- Content + Loading overlay -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

                <!-- ===== SCROLLABLE CONTENT ===== -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/main_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- ===== FEATURED BANNER SECTION ===== -->
                        <LinearLayout
                            android:id="@+id/section_trending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <!-- Featured Banner (left, large) -->
                            <FrameLayout
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_weight="1.6"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/trending_card_bg"
                                android:clipChildren="true">

                                <!-- Banner image -->
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/bg_anime_1"
                                    android:scaleType="centerCrop"/>

                                <!-- Gradient overlay -->
                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/tvx_banner_overlay"/>

                                <!-- Banner text content -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="bottom"
                                    android:orientation="vertical"
                                    android:padding="14dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hololive Highlights"
                                        android:textColor="@color/color_text"
                                        android:textSize="16sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Best Moments"
                                        android:textColor="@color/color_text_secondary"
                                        android:textSize="11sp"/>

                                    <!-- Dot indicators -->
                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:layout_marginTop="6dp">
                                        <View android:layout_width="18dp" android:layout_height="3dp"
                                            android:background="@color/color_primary"
                                            android:layout_marginEnd="3dp"/>
                                        <View android:layout_width="6dp" android:layout_height="3dp"
                                            android:background="@color/color_text_dim"
                                            android:layout_marginEnd="3dp"/>
                                        <View android:layout_width="6dp" android:layout_height="3dp"
                                            android:background="@color/color_text_dim"
                                            android:layout_marginEnd="3dp"/>
                                        <View android:layout_width="6dp" android:layout_height="3dp"
                                            android:background="@color/color_text_dim"/>
                                    </LinearLayout>
                                </LinearLayout>

                            </FrameLayout>

                            <!-- Right stats panel -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="170dp"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:padding="12dp"
                                android:background="@drawable/trending_card_bg">

                                <!-- Title row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="10dp">
                                    <View android:layout_width="3dp" android:layout_height="14dp"
                                        android:background="@color/color_primary"
                                        android:layout_marginEnd="8dp"/>
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="ANIME TV"
                                        android:textColor="@color/color_text"
                                        android:textSize="12sp"
                                        android:textStyle="bold"/>
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="ANIME"
                                        android:textSize="7sp"
                                        android:textColor="@color/color_primary"
                                        android:background="@drawable/drm_badge_bg"
                                        android:paddingStart="6dp"
                                        android:paddingEnd="6dp"
                                        android:paddingTop="2dp"
                                        android:paddingBottom="2dp"/>
                                </LinearLayout>

                                <!-- Stats row -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical"
                                        android:gravity="center" android:padding="6dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="3dp">
                                        <TextView android:id="@+id/stat_total"
                                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="0" android:textSize="15sp" android:textStyle="bold"
                                            android:textColor="@color/color_primary" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="CH" android:textSize="7sp" android:textColor="@color/color_text_secondary"/>
                                    </LinearLayout>

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical"
                                        android:gravity="center" android:padding="6dp"
                                        android:background="@drawable/stats_badge_bg"
                                        android:layout_marginEnd="3dp">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="HD" android:textSize="13sp" android:textStyle="bold"
                                            android:textColor="@color/color_accent" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="VIDEO" android:textSize="7sp" android:textColor="@color/color_text_secondary"/>
                                    </LinearLayout>

                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical"
                                        android:gravity="center" android:padding="6dp"
                                        android:background="@drawable/stats_badge_bg">
                                        <TextView android:id="@+id/stat_custom"
                                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="0" android:textSize="15sp" android:textStyle="bold"
                                            android:textColor="@color/color_green" android:fontFamily="monospace"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="FAV" android:textSize="7sp" android:textColor="@color/color_text_secondary"/>
                                    </LinearLayout>
                                </LinearLayout>

                                <!-- LIVE status -->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:padding="8dp"
                                    android:layout_marginTop="8dp"
                                    android:background="@drawable/user_card_bg">
                                    <View android:layout_width="6dp" android:layout_height="6dp"
                                        android:background="@drawable/dot_green"
                                        android:layout_marginEnd="6dp"/>
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                        android:layout_weight="1" android:orientation="vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="Live Streaming"
                                            android:textColor="@color/color_text"
                                            android:textSize="10sp" android:textStyle="bold"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="AKTIF"
                                            android:textColor="@color/color_green"
                                            android:textSize="8sp"/>
                                    </LinearLayout>
                                    <com.github.ybq.android.spinkit.SpinKitView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        app:SpinKit_Style="Wave"
                                        app:SpinKit_Color="@color/color_accent"/>
                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- ===== Search bar below banner ===== -->
                        <LinearLayout
                            android:id="@+id/search_bar_container"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/search_bg"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginBottom="4dp"
                            android:focusable="true"
                            android:clickable="true">
                            <TextView
                                android:id="@+id/search_hint"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Cari channel anime..."
                                android:textColor="#40FFFFFF"
                                android:textSize="12sp"/>
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                app:srcCompat="@drawable/ic_search"
                                android:tint="#40FFFFFF"/>
                        </LinearLayout>

                        <!-- LIVE badge row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="2dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="24dp"
                                android:orientation="horizontal"
                                android:gravity="center"
                                android:background="@drawable/live_badge_bg"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp">
                                <View android:layout_width="5dp" android:layout_height="5dp"
                                    android:background="@drawable/dot_red"
                                    android:layout_marginEnd="4dp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="LIVE"
                                    android:textColor="@android:color/white"
                                    android:textSize="9sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                            <!-- Resolution buttons top row -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView android:id="@+id/btn360" style="@style/ResBtn" android:text="360p" android:layout_width="40dp"/>
                                <TextView android:id="@+id/btn720" style="@style/ResBtnActive" android:text="720p" android:layout_width="40dp" android:layout_marginStart="2dp"/>
                                <TextView android:id="@+id/btn1080" style="@style/ResBtn" android:text="1080p" android:layout_width="44dp" android:layout_marginStart="2dp"/>
                                <TextView android:id="@+id/btn4k" style="@style/ResBtn" android:text="4K" android:layout_width="32dp" android:layout_marginStart="2dp"/>
                                <TextView android:id="@+id/btnAuto" style="@style/ResBtn" android:text="Auto" android:layout_width="40dp" android:layout_marginStart="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ===== CHANNEL CATEGORIES ===== -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adapter="@{catAdapter}"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="12dp"
                            tools:listitem="@layout/item_category"/>

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Shimmer loading overlay -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shimmer_auto_start="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include layout="@layout/item_category_dummy"/>
                        <include layout="@layout/item_category_dummy"/>
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Character guide (bottom right) -->
    <LinearLayout
        android:id="@+id/character_guide_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/guide_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/quote_card_bg"
            android:padding="10dp"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="12dp"
            android:maxWidth="160dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txt_guide_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:lineSpacingMultiplier="1.3"
                tools:text="Selamat datang di TVX AnimeTV!"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txt_anime_character"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="32sp"
            android:text="@"
            android:layout_gravity="end"/>
    </LinearLayout>

    </FrameLayout>
</layout>

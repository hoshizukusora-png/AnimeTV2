<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <data>
        <variable name="catAdapter" type="com.animatv.player.adapter.CategoryAdapter"/>
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background"
        tools:context=".MainActivity">

    <!-- ===== ANIME BACKGROUND ROTATOR ===== -->
    <ImageView
        android:id="@+id/img_anime_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_anime_1"
        android:scaleType="centerCrop"
        android:alpha="0.18"/>

    <!-- ===== SAKURA EFFECT CONTAINER ===== -->
    <FrameLayout
        android:id="@+id/sakura_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"/>

    <!-- ===== MAIN UI ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- ===== SIDEBAR ANIME ===== -->
        <LinearLayout
            android:id="@+id/sidebar"
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/sidebar_bg">

            <!-- Header anime -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:background="@drawable/sidebar_header_bg">

                <!-- Pink accent line -->
                <View android:layout_width="28dp" android:layout_height="2dp"
                    android:background="@color/color_primary" android:layout_marginBottom="10dp"/>

                <!-- App name - tap 7x untuk admin panel -->
                <TextView
                    android:id="@+id/txt_app_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STAR"
                    android:textColor="@color/color_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VISION TV"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="10dp"/>

                <!-- Live status card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:padding="8dp" android:background="@drawable/user_card_bg">

                    <View android:layout_width="7dp" android:layout_height="7dp"
                        android:background="@drawable/dot_green" android:layout_marginEnd="8dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Live Streaming" android:textColor="@color/color_text"
                            android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AKTIF" android:textSize="8sp"
                            android:textColor="@color/color_green"/>
                    </LinearLayout>

                    <!-- SpinKit mini -->
                    <com.github.ybq.android.spinkit.SpinKitView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:SpinKit_Style="Wave"
                        app:SpinKit_Color="@color/color_accent"/>
                </LinearLayout>
            </LinearLayout>

            <!-- DROPDOWN MENU HEADER (seperti GVision) -->
            <LinearLayout
                android:id="@+id/layout_dropdown_header"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:background="@color/color_surface_2"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/txt_current_menu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LIVE TV"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/txt_dropdown_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingStart="4dp"/>

            </LinearLayout>

            <!-- DROPDOWN MENU CONTAINER (muncul saat header diklik) -->
            <ScrollView
                android:id="@+id/dropdown_menu_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="300dp"
                android:visibility="gone"
                android:background="#EE0D0D1A"
                android:elevation="8dp">

                <LinearLayout
                    android:id="@+id/dropdown_items_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </ScrollView>

            <!-- Category list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sidebar"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"/>

            <!-- Footer: quality selector -->
            <!-- ===== QUOTE OF THE DAY CARD ===== -->
            <LinearLayout
                android:id="@+id/quote_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/quote_card_bg"
                android:visibility="gone">

                <!-- Tanda kutip + nama anime -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&quot;"
                        android:textColor="@color/color_primary"
                        android:textSize="16sp"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/txt_quote_anime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/color_primary"
                        android:textSize="7sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        tools:text="NARUTO"/>
                </LinearLayout>

                <!-- Isi quote -->
                <TextView
                    android:id="@+id/txt_quote_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="8.5sp"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    tools:text="Jangan menyerah! Seseorang yang menyerah adalah orang yang lemah."/>

                <!-- Nama karakter -->
                <TextView
                    android:id="@+id/txt_quote_character"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_dim"
                    android:textSize="7sp"
                    android:gravity="end"
                    tools:text="- Naruto Uzumaki"/>

            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:paddingTop="8dp" android:paddingBottom="10dp"
                android:background="@drawable/sidebar_footer_bg">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RESOLUSI" android:textSize="7sp"
                    android:textColor="@color/color_text_dim"
                    android:letterSpacing="0.2"
                    android:paddingBottom="5dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btn360" style="@style/ResBtn" android:text="360p"/>
                    <TextView android:id="@+id/btn720" style="@style/ResBtnActive" android:text="720p" android:layout_marginStart="2dp"/>
                    <TextView android:id="@+id/btn1080" style="@style/ResBtn" android:text="1080p" android:layout_marginStart="2dp"/>
                    <TextView android:id="@+id/btn4k" style="@style/ResBtn" android:text="4K" android:layout_marginStart="2dp"/>
                    <TextView android:id="@+id/btnAuto" style="@style/ResBtn" android:text="Auto" android:layout_marginStart="2dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Sidebar separator -->
        <View android:layout_width="0.5dp" android:layout_height="match_parent"
            android:background="#20FFFFFF"/>

        <!-- ===== MAIN AREA ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:background="@drawable/topbar_bg">

                <!-- Category title with pink accent -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">
                    <View android:layout_width="2dp" android:layout_height="18dp"
                        android:background="@color/color_primary" android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/text_current_cat"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SEMUA CHANNEL"
                        android:textColor="@color/color_text" android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Search bar -->
                <LinearLayout
                    android:id="@+id/search_bar_container"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/search_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:focusable="true"
                    android:clickable="true">
                    <TextView android:id="@+id/search_hint"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="* Cari channel anime..." android:textColor="#30FFFFFF"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- LIVE badge -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="26dp"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/live_badge_bg"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:layout_marginStart="8dp">
                    <View android:layout_width="5dp" android:layout_height="5dp"
                        android:background="@drawable/dot_red" android:layout_marginEnd="5dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="LIVE" android:textSize="9sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Real-time clock -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center"
                    android:layout_marginStart="8dp" android:layout_marginEnd="4dp">
                    <TextView android:id="@+id/text_clock"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="00:00" android:textColor="@color/color_accent"
                        android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/text_date"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Senin" android:textColor="#66FFFFFF"
                        android:textSize="8sp"/>
                </LinearLayout>

                <!-- Action buttons -->
                <ImageButton android:id="@+id/button_search" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_search" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_refresh" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_settings" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_refresh" android:layout_marginStart="4dp"/>
                <ImageButton android:id="@+id/button_exit" style="@style/ImageButtonMain"
                    app:srcCompat="@drawable/ic_exit" android:layout_marginStart="4dp"/>

            </LinearLayout>

            <!-- Bottom border of topbar -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="#20FFFFFF"/>

            <!-- Content + loading overlay -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

                <!-- Main scroll content -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/main_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fillViewport="true">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Info card -->
                        <LinearLayout
                            android:id="@+id/section_trending"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <!-- Left: Stats card -->
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:padding="14dp"
                                    android:background="@drawable/trending_card_bg"
                                    android:layout_marginEnd="8dp">

                                    <!-- Title row -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                        android:orientation="horizontal" android:gravity="center_vertical"
                                        android:layout_marginBottom="12dp">
                                        <View android:layout_width="3dp" android:layout_height="14dp"
                                            android:background="@color/color_primary" android:layout_marginEnd="10dp"/>
                                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:text="STARVISION TV"
                                            android:textColor="@color/color_text"
                                            android:textStyle="bold"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                            android:text="STAR"
                                            android:textSize="8sp" android:textColor="@color/color_primary"
                                            android:background="@drawable/drm_badge_bg"
                                            android:paddingStart="6dp" android:paddingEnd="6dp"
                                            android:paddingTop="2dp" android:paddingBottom="2dp"/>
                                    </LinearLayout>

                                    <!-- Stats row -->
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                        android:orientation="horizontal">

                                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                            android:padding="8dp" android:background="@drawable/stats_badge_bg"
                                            android:layout_marginEnd="4dp">
                                            <TextView android:id="@+id/stat_total"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="0" android:textSize="16sp" android:textStyle="bold"
                                                android:textColor="@color/color_primary" android:fontFamily="monospace"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="CHANNEL" android:textSize="7sp"/>
                                        </LinearLayout>

                                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                            android:padding="8dp" android:background="@drawable/stats_badge_bg"
                                            android:layout_marginEnd="4dp">
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="DASH" android:textSize="14sp" android:textStyle="bold"
                                                android:textColor="@color/color_accent" android:fontFamily="monospace"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="FORMAT" android:textSize="7sp"/>
                                        </LinearLayout>

                                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                            android:padding="8dp" android:background="@drawable/stats_badge_bg"
                                            android:layout_marginEnd="4dp">
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="DRM" android:textSize="14sp" android:textStyle="bold"
                                                android:textColor="@color/color_purple" android:fontFamily="monospace"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="SECURE" android:textSize="7sp"/>
                                        </LinearLayout>

                                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                            android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                                            android:padding="8dp" android:background="@drawable/stats_badge_bg">
                                            <TextView android:id="@+id/stat_custom"
                                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="0" android:textSize="16sp" android:textStyle="bold"
                                                android:textColor="@color/color_green" android:fontFamily="monospace"/>
                                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:text="CUSTOM" android:textSize="7sp"/>
                                        </LinearLayout>

                                    </LinearLayout>
                                </LinearLayout>

                                <!-- Right: Anime image card -->
                                <LinearLayout android:layout_width="180dp" android:layout_height="match_parent"
                                    android:orientation="vertical"
                                    android:background="@drawable/trending_card_bg">

                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="0dp"
                                        android:layout_weight="1"
                                        android:src="@drawable/bg_anime_1"
                                        android:scaleType="centerCrop"/>

                                    <TextView
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="* WATCH ANIME CHANNEL"
                                        android:textColor="@color/color_primary"
                                        android:textSize="8sp"
                                        android:gravity="center"
                                        android:padding="6dp"/>
                                </LinearLayout>

                            </LinearLayout>
                        </LinearLayout>

                        <!-- Channel grid by category -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:adapter="@{catAdapter}"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="12dp"
                            tools:listitem="@layout/item_category"/>

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Shimmer loading overlay -->
                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:shimmer_auto_start="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical">
                        <include layout="@layout/item_category_dummy"/>
                        <include layout="@layout/item_category_dummy"/>
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ===== ANIME CHARACTER GUIDE (pojok kanan bawah) ===== -->
    <LinearLayout
        android:id="@+id/character_guide_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <!-- Speech bubble -->
        <LinearLayout
            android:id="@+id/guide_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/quote_card_bg"
            android:padding="10dp"
            android:layout_marginBottom="4dp"
            android:layout_marginEnd="12dp"
            android:maxWidth="160dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_guide_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:lineSpacingMultiplier="1.3"
                tools:text="Selamat datang di StarVision TV! Pilih channel favoritmu *"/>
        </LinearLayout>

        <!-- Karakter anime (pakai text emoji sebagai placeholder) -->
        <TextView
            android:id="@+id/txt_anime_character"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="32sp"
            android:text="@"
            android:layout_gravity="end"/>

    </LinearLayout>


    </FrameLayout>
</layout>

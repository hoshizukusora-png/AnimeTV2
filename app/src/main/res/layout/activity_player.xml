<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".PlayerActivity">

        <!-- ExoPlayer view fullscreen -->
        <com.google.android.exoplayer2.ui.PlayerView
            android:id="@+id/player_view"
            android:background="@android:color/black"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:resize_mode="zoom"
            app:played_color="@color/color_primary"
            app:show_subtitle_button="true"
            app:show_buffering="always"
            app:controller_layout_id="@layout/custom_control"
            app:keep_content_on_player_reset="true"/>

        <!-- Channel info OSD top left -->
        <LinearLayout
            android:id="@+id/layout_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/player_info_margin_start"
            android:layout_marginTop="@dimen/player_info_margin_start"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:focusable="false"
            android:orientation="vertical"
            android:visibility="invisible"
            tools:visibility="visible">

            <TextView
                android:id="@+id/category_name"
                style="@style/TextAppearance.AppCompat.Small"
                android:background="@drawable/osd_text_background"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/ch_name_padding"
                android:gravity="start|center_vertical"
                android:paddingStart="@dimen/exo_icon_padding_bottom"
                android:paddingEnd="@dimen/exo_icon_padding_bottom"
                android:textAllCaps="true"
                android:textColor="@color/color_accent"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="KATEGORI"/>

            <TextView
                android:id="@+id/channel_name"
                style="@style/TextAppearance.AppCompat.Small"
                android:background="@drawable/osd_text_background"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/player_info_margin_space"
                android:padding="@dimen/ch_name_padding"
                android:gravity="start|center_vertical"
                android:paddingStart="@dimen/exo_icon_padding_bottom"
                android:paddingEnd="@dimen/exo_icon_padding_bottom"
                android:textAllCaps="true"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="NAMA CHANNEL"/>

        </LinearLayout>

        <!-- MINI CHANNEL PANEL (kanan) -->
        <LinearLayout
            android:id="@+id/mini_channel_panel"
            android:layout_width="88dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:background="#CC0D0D1A"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="* CHANNEL"
                android:textColor="@color/color_primary"
                android:textSize="8sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#40E91E8C"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_mini_channels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"/>

        </LinearLayout>

        <!-- Toggle button show/hide panel -->
        <ImageButton
            android:id="@+id/btn_mini_channel_toggle"
            android:layout_width="22dp"
            android:layout_height="60dp"
            android:background="@drawable/mini_channel_bg"
            android:src="@drawable/ic_player_previous"
            android:scaleType="fitCenter"
            android:padding="4dp"
            android:tint="@color/color_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="ContentDescription"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

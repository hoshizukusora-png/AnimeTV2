<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        tools:context=".SplashActivity">

        <!-- FULL SCREEN VIDEO - Symphogear Opening -->
        <VideoView
            android:id="@+id/splashVideoView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Loading bar tipis di bawah layar -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="#33FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:id="@+id/loadingBar"
                android:layout_width="0dp"
                android:layout_height="3dp"
                android:background="@drawable/bar_fill"/>

        </FrameLayout>

        <!-- Hidden views required by SplashActivity.kt - JANGAN DIHAPUS -->
        <TextView android:id="@+id/textStatus"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/textUsers"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/textPresents"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/textTitle"
            android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>

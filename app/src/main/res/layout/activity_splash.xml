<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_background"
        tools:context=".SplashActivity">

        <!-- Anime background image -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/bg_anime_1"
            android:scaleType="centerCrop"
            android:alpha="0.18"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Top pink line -->
        <View android:id="@+id/lineTop"
            android:layout_width="0dp" android:layout_height="2dp"
            android:background="@color/color_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Left branding column -->
        <LinearLayout
            android:id="@+id/leftColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="56dp"
            android:paddingEnd="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/divider">

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦ ANIME IPTV PLAYER ✦"
                android:textColor="#55E91E8C"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="14dp"/>

            <!-- App name big - ANIME style -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANIME"
                android:textColor="@color/color_primary"
                android:textSize="42sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELEVISION"
                android:textColor="@color/color_text"
                android:textSize="22sp"
                android:layout_marginBottom="28dp"/>

            <!-- Pink divider -->
            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="@color/color_primary"
                android:layout_marginBottom="20dp"/>

            <!-- Lottie loading animation -->
            <com.airbnb.lottie.LottieAnimationView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:lottie_fileName="loading_anime.json"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                android:layout_marginBottom="12dp"/>

            <!-- Status -->
            <TextView
                android:id="@+id/textStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Memuat..."
                android:textColor="@color/color_text_dim"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"/>

            <!-- Loading bar track -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="2dp"
                android:background="@drawable/bar_track"
                android:layout_marginBottom="24dp">
                <View
                    android:id="@+id/loadingBar"
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:background="@drawable/bar_fill"/>
            </FrameLayout>

            <!-- Contributors -->
            <TextView
                android:id="@+id/textUsers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#25E91E8C"
                android:textSize="8sp"
                android:text=""/>

        </LinearLayout>

        <!-- Vertical divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0.5dp"
            android:layout_height="0dp"
            android:background="#18E91E8C"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftColumn"
            app:layout_constraintEnd_toStartOf="@id/rightColumn"/>

        <!-- Right info column -->
        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingEnd="56dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/divider">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FITUR UNGGULAN"
                android:textColor="#40E91E8C"
                android:textSize="8sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="18dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  DASH + DRM ClearKey &amp; Widevine" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  Sidebar kategori channel" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  Ganti channel tanpa keluar player" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  Pengaturan resolusi nyata &amp; ukuran layar" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  Favorit &amp; pencarian channel" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="10dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▶  Tema Anime penuh" android:textColor="@color/color_text_secondary"
                android:textSize="12sp" android:layout_marginBottom="28dp"/>

            <!-- Status badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="@drawable/stats_badge_bg">

                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@drawable/dot_green" android:layout_marginEnd="8dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SIAP DIGUNAKAN" android:textColor="@color/color_green"
                    android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Anime character image -->
            <ImageView
                android:layout_width="160dp"
                android:layout_height="120dp"
                android:src="@drawable/bg_anime_2"
                android:scaleType="centerCrop"
                android:layout_marginTop="20dp"
                android:alpha="0.7"/>

        </LinearLayout>

        <!-- Hidden views required by SplashActivity.kt -->
        <TextView android:id="@+id/textPresents" android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
        <TextView android:id="@+id/textTitle" android:layout_width="0dp" android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

        <!-- Bottom pink line -->
        <View android:layout_width="0dp" android:layout_height="2dp"
            android:background="@color/color_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

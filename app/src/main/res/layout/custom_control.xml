<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/custom_control"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:ignore="ContentDescription">

        <!-- Exit button (top right) -->
        <ImageButton
            android:id="@+id/button_exit"
            android:layout_marginEnd="@dimen/player_info_margin_start"
            android:layout_marginTop="27dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_player_close"
            style="@style/ImageButtonClose" />

        <!-- PIP button (top right, sebelah exit) -->
        <TextView
            android:id="@+id/btn_pip"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="⊡"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:background="@drawable/osd_text_background"
            android:layout_marginTop="27dp"
            android:layout_marginEnd="8dp"
            android:padding="4dp"
            app:layout_constraintEnd_toStartOf="@id/button_exit"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription"/>

        <!-- Sleep Timer indicator (top left) -->
        <TextView
            android:id="@+id/txt_sleep_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/osd_text_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/color_accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="😴 30:00"
            tools:visibility="visible"/>

        <!-- Double tap ripple left (rewind) -->
        <TextView
            android:id="@+id/txt_double_tap_left"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="⏪\n-10s"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:background="#40000000"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible"/>

        <!-- Double tap ripple right (forward) -->
        <TextView
            android:id="@+id/txt_double_tap_right"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="+10s\n⏩"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:background="#40000000"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:visibility="visible"/>

        <!-- Brightness indicator (gesture) -->
        <LinearLayout
            android:id="@+id/layout_brightness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/osd_text_background"
            android:padding="12dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="40dp"
            tools:visibility="visible">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="☀️" android:textSize="20sp" android:gravity="center"/>
            <TextView android:id="@+id/txt_brightness_value"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@android:color/white" android:textSize="12sp"
                android:gravity="center" tools:text="80%"/>
        </LinearLayout>

        <!-- Volume indicator (gesture) -->
        <LinearLayout
            android:id="@+id/layout_volume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/osd_text_background"
            android:padding="12dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="40dp"
            tools:visibility="visible">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔊" android:textSize="20sp" android:gravity="center"/>
            <TextView android:id="@+id/txt_volume_value"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@android:color/white" android:textSize="12sp"
                android:gravity="center" tools:text="80%"/>
        </LinearLayout>

        <!-- Main control buttons (bottom left) -->
        <LinearLayout
            android:id="@+id/layout_control"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/button_previous"
                app:srcCompat="@drawable/ic_player_previous"
                style="@style/ImageButtonControl" />

            <ImageButton
                android:id="@+id/button_rewind"
                app:srcCompat="@drawable/ic_player_rewind"
                style="@style/ImageButtonControl"
                android:visibility="gone"
                tools:visibility="visible" />

            <ImageButton
                android:id="@+id/exo_play"
                app:srcCompat="@drawable/ic_player_play"
                style="@style/ImageButtonControl" />

            <ImageButton
                android:id="@+id/exo_pause"
                app:srcCompat="@drawable/ic_player_pause"
                style="@style/ImageButtonControl" />

            <ImageButton
                android:id="@+id/button_forward"
                app:srcCompat="@drawable/ic_player_forward"
                style="@style/ImageButtonControl"
                android:visibility="gone"
                tools:visibility="visible" />

            <ImageButton
                android:id="@+id/button_next"
                app:srcCompat="@drawable/ic_player_next"
                style="@style/ImageButtonControl" />

        </LinearLayout>

        <View
            android:id="@+id/spacer_control"
            android:layout_width="0dp"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@id/layout_control"
            app:layout_constraintEnd_toStartOf="@id/screen_mode"
            app:layout_constraintBottom_toBottomOf="parent"
            style="@style/ImageButtonControl"
            tools:visibility="visible"/>

        <!-- Speed button -->
        <TextView
            android:id="@+id/btn_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1x"
            android:textColor="@color/color_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/osd_text_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_sleep"
            android:layout_marginBottom="8dp"
            android:layout_marginEnd="4dp"/>

        <!-- Sleep Timer button -->
        <TextView
            android:id="@+id/btn_sleep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😴"
            android:textSize="16sp"
            android:background="@drawable/osd_text_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/screen_mode"
            android:layout_marginBottom="8dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/screen_mode"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/track_selection"
            app:srcCompat="@drawable/ic_aspect_ratio"
            style="@style/ImageButtonControl" />

        <ImageButton
            android:id="@+id/track_selection"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/button_lock"
            app:srcCompat="@drawable/ic_track_selector"
            style="@style/ImageButtonControl" />

        <ImageButton
            android:id="@+id/button_lock"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_lock_open"
            style="@style/ImageButtonControl" />

        <LinearLayout
            android:id="@+id/layout_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@id/layout_control"
            android:background="@drawable/button_control_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:includeFontPadding="false"
                android:textColor="#FFBEBEBE"
                tools:text="12:34" />

            <View android:id="@id/exo_progress_placeholder"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="26dp" />

            <TextView android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:includeFontPadding="false"
                android:textColor="#FFBEBEBE"
                tools:text="56:78" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>

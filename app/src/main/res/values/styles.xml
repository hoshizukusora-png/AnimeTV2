<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_background</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
        <!-- TV Remote Navigation -->
        <item name="android:focusable">true</item>
    </style>

    <style name="AppThemePlayer" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryDark">@color/color_background</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Tombol atas: search, refresh, setting, keluar -->
    <style name="ImageButtonMain">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/button_control_background</item>
        <item name="android:padding">9dp</item>
        <item name="android:tint">@color/color_text</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:clickable">true</item>
        <!-- Tint berubah saat fokus jadi gelap agar terlihat di atas kuning -->
        <item name="android:duplicateParentState">false</item>
    </style>

    <style name="ImageButtonBase">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:background">@drawable/button_control_background</item>
        <item name="android:padding">9dp</item>
        <item name="android:tint">@color/color_text</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:clickable">true</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="ImageButtonControl" parent="ImageButtonBase">
        <item name="android:layout_width">46dp</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:padding">10dp</item>
        <item name="android:tint">@color/color_text</item>
    </style>

    <style name="ImageButtonClose" parent="ImageButtonBase">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:padding">9dp</item>
    </style>

    <style name="ResBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/color_text_secondary</item>
        <item name="android:background">@drawable/res_btn_bg</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="ResBtnActive">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">@color/color_background</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/res_btn_active_bg</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="TextAppearance.OSD" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/osd_text_background</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="SettingsDialogThemeOverlay" parent="Theme.AppCompat.Dialog">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
    </style>

    <style name="TrackSelectionDialogThemeOverlay" parent="Theme.AppCompat.Dialog">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorAccent">@color/color_accent</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:textColor">@color/color_text</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
    </style>
</resources>
